Algoritmo sin_titulo
	Imprimir 'proprciona un numero: '
	leer mi_numero
	si mi_numero > 0 Entonces
		imprimir 'valor positivo: ' mi_numero
	SiNo 
		si mi_numero < 0 entonces	
			imprimir 'valor negativo: ', mi_numero
		sino 
			Imprimir 'Valor es cero: ', mi_numero
		FinSi
	FinSi
FinAlgoritmo
