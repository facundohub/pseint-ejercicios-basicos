Algoritmo Operadores_relacionales
	//operadores relacionales
	// operadores de igualdad
	a = 5 == 6
	Imprimir 'opeador de igualdad: ', a
	
	b = 10 == 10
	Imprimir 'operador de igualdad ' b
	
	//operador diferente
	
	c = 5 <> 6
	Imprimir 'operador de distino ' c
	
	d = 10 <> 10
	Imprimir 'operador de distinto ' d
	
	// operador mayor que 
	
	e = 6 > 6 
	Imprimir 'operador mayor que ' e
	
	f = 10 >= 10
	Imprimir 'operador mayor o igual que ' f // o <= 
	
FinAlgoritmo
