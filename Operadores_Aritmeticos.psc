Algoritmo Operadores_Aritmeticos
	//suma
	a = 10 + 4
	imprimir "suma: ", a
	// resta
	b = 10 - 4
	imprimir "resta ", b
	//multiplicación
	c = a * 2
	imprimir "multiplicacion: ", c
	//division
	d = b / c
	imprimir "division ", d
	//potencia
	e = a ^ 2
	imprimir "potencia ", e
	//modulo residuo division
	f = 9 % 3
	Imprimir "modulo ", f
FinAlgoritmo

