Algoritmo explicacion_while
	//accion repetida ciclo while se itera infinitamente si no se usa el contador. 
	
	definir contador, repeticiones Como Entero
	contador = 0 //iterador
	repeticiones = 5 
	//definimo ciclo mientras hacer 'while'
	Mientras contador < repeticiones  Hacer
		imprimir  'u can do it vikiingo'
		contador = contador + 1
		condicion = conador < repeticiones
		imprimir conador, ' < ', repeticiones, ' = ', condicion
	FinMientras
	
FinAlgoritmo
